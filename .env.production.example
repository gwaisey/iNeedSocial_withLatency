# Variabel frontend untuk build aplikasi peserta di produksi.
# Gunakan R2 public origin untuk video feed. Contoh: https://pub-xxxxxxxx.r2.dev
VITE_FEED_SOURCE=mock
VITE_VIDEO_PUBLIC_BASE_URL=
VITE_VIDEO_COMPACT_PUBLIC_BASE_URL=
VITE_SUPABASE_URL=https://your-project-id.supabase.co
VITE_SUPABASE_PUBLISHABLE_KEY=your-publishable-key

# Variabel privat untuk tooling admin / server-side.
# Simpan hanya di secret manager hosting atau shell lokal yang aman.
SUPABASE_URL=https://your-project-id.supabase.co
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key
